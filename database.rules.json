{
  "rules": {
    ".read": false,
    ".write": false,

    "appState": {
      "projects": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      },
      "progress": {
        "$uid": {
          ".read": "auth != null",
          ".write": "auth != null && $uid === auth.uid"
        }
      },
      "docData": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      },
      "statusMessage": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).exists()",
      "$uid": {
        ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "newData.hasChildren(['id', 'name', 'email', 'role', 'partyId'])"
      }
    },

    "pendingUsers": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "newData.hasChildren(['id', 'name', 'email']) || newData.val() === null"
      }
    }
  }
}
